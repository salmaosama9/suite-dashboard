# Mixpanel Service Account credentials
# Create at: mixpanel.com → Settings → Organization Settings → Service Accounts
# The same service account must have access to BOTH projects below.

MIXPANEL_SERVICE_USERNAME=your_service_account_username
MIXPANEL_SERVICE_SECRET=your_service_account_secret

# Project IDs (already wired in the code — only change if you use different projects)
# MIXPANEL_APP_PROJECT_ID=3822028
# MIXPANEL_CRM_PROJECT_ID=3101947
